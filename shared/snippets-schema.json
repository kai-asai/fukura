{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kai-fsc-dev.example/fukura/snippets.schema.json",
  "title": "fukura snippets.json",
  "type": "object",
  "required": ["version", "snippets"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": 1
    },
    "updated_at": {
      "type": "string"
    },
    "snippets": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "required": ["id", "trigger", "body"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "trigger": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8000
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "updated_at": {
            "type": "string"
          }
        }
      }
    }
  }
}
